# Telegram Bot
TOKEN=your_telegram_bot_token_here
DEBUG=false

# Limits
MAX_SOURCE_MB=800
MAX_RESULT_MB=1900
PER_USER_RPM=8

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# ElevenLabs
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_voice_id_here

# Exolyt API (optional)
EXOLYT_API_KEY=

# Shotstack (optional)
SHOTSTACK_API_KEY=
SHOTSTACK_STAGE=stage

# TikTok API (optional; Business Content Posting)
TIKTOK_ACCESS_TOKEN=
TIKTOK_ADVERTISER_ID=

# Paths
DATA_DIR=data
DB_PATH=data/bot.sqlite
TMP_DIR=data/tmp

# FFmpeg
FFMPEG_BIN=ffmpeg
FFMPEG_THREADS=2